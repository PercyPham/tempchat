APP_MODE=dev
PORT=8080
REDIS_ADDR=127.0.0.1:6379
ALLOWED_ORIGINS=http://localhost:5173
GIN_MODE=debug
APP_BASE_URL=https://app.tempchat.app

# SePay (Vietnam bank transfer)
# Webhook API key — used to authenticate incoming bank-transfer monitoring callbacks
SEPAY_WEBHOOK_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Bank account info — returned to frontend for QR code and payment instructions
SEPAY_ACCOUNT_NUMBER=XXXXXXXXXXXXXXXX
SEPAY_BANK_CODE=XXXXXXX
SEPAY_BANK_NAME=XXXXXXX

# Polar (global USD checkout)
POLAR_ENV=production  # "production" or "sandbox"
POLAR_ACCESS_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
POLAR_WEBHOOK_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
POLAR_PRODUCT_ID_BOOST_PLUS=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
POLAR_PRODUCT_ID_BOOST_PRO=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Boost prices in VND (defaults: 20000 / 50000)
BOOST_PLUS_VND=20000
BOOST_PRO_VND=50000
